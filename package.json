{
  "name": "sql-email",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run css:build && bun run css:watch & bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "css:build": "bunx @tailwindcss/cli -i src/styles/app.css -o public/styles.css --minify",
    "css:watch": "bunx @tailwindcss/cli -i src/styles/app.css -o public/styles.css --watch",
    "build": "bun run css:build",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --write src/",
    "format": "bunx biome format --write src/",
    "seed:admin": "bun run src/seed-admin.ts",
    "test": "bun test"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "nodemailer": "^8.0.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2"
  }
}
