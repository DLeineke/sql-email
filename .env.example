DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sql_email
PORT=3001

# SMTP configuration for outbound email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
EMAIL_FROM=noreply@example.com

# Cron schedule for daily reminder processing (default: 8:00 AM every day)
REMINDER_CRON=0 8 * * *

# Timezone used to determine "today" when matching reminder dates (IANA name, default: UTC)
TZ_REMINDERS=America/New_York

# Public base URL used to generate unsubscribe links in emails
APP_BASE_URL=https://your-domain.example.com
